    const statusMatch = !statusFilter || data.status === statusFilter;
    const barkasMatch = !barkasFilter || data.berkas_status === (barkasFilter === 'Sudah' ? 'Sudah' : 'Belum');
    
    return (nameMatch || nisnMatch) && statusMatch && barkasMatch;
  });
  
  const tbody = document.getElementById('data-table-body');
  if (filtered.length === 0) {
    tbody.innerHTML = '<tr><td colspan="9" class="px-6 py-12 text-center text-gray-500">Tidak ada data yang cocok</td></tr>';
    return;

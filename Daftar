function populateJurusanSelects() {
  const select1 = document.getElementById('jurusan-select-1');
  const select2 = document.getElementById('jurusan-select-2');
  const options = jurusanList.map(j => `<option value="${j.nama}">${j.nama} (${j.kode})</option>`).join('');
  select1.innerHTML = '<option value="">-- Pilih Jurusan --</option>' + options;
  select2.innerHTML = '<option value="">-- Pilih Jurusan --</option>' + options;

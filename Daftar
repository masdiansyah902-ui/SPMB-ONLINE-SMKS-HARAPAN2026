        </span>
      </td>
      <td class="px-6 py-4">
        <span class="px-3 py-1 rounded-full text-xs font-bold status-badge-${data.status.toLowerCase()}">
          ${data.status || 'Menunggu'}
        </span>
      </td>
      <td class="px-6 py-4 text-gray-600 text-sm">${new Date(data.tanggal_daftar).toLocaleDateString('id-ID') || '-'}</td>

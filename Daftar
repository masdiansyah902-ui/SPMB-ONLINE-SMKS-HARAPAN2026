function createCharts() {
  const statusCtx = document.getElementById('status-chart');
  if (statusCtx && allData.length > 0) {
    const pending = allData.filter(d => d.status === 'Menunggu').length;
    const accepted = allData.filter(d => d.status === 'Diterima').length;
    const rejected = allData.filter(d => d.status === 'Ditolak').length;
    
    new Chart(statusCtx, {
      type: 'doughnut',
      data: {
        labels: ['Menunggu', 'Diterima', 'Ditolak'],
        datasets: [{
          data: [pending, accepted, rejected],
          backgroundColor: ['#FCD34D', '#10B981', '#EF4444'],
          borderColor: ['#FBD38D', '#6EE7B7', '#F87171'],
          borderWidth: 2
        }]
      },
      options: {
        responsive: true,
        plugins: { legend: { position: 'bottom' } }
      }
    });
  }
  
  const jurusanCtx = document.getElementById('jurusan-chart');
  if (jurusanCtx && allData.length > 0) {
    const jurusanCount = {};
    allData.forEach(data => {
      const jurusan = data.jurusan_pilihan_1 || 'Unknown';
      jurusanCount[jurusan] = (jurusanCount[jurusan] || 0) + 1;
    });
    
    const sortedJurusan = Object.entries(jurusanCount)
      .sort((a, b) => b[1] - a[1])
      .slice(0, 5);
    
    new Chart(jurusanCtx, {
      type: 'bar',
      data: {
        labels: sortedJurusan.map(j => j[0].substring(0, 15) + '...'),
        datasets: [{
          label: 'Jumlah Pendaftar',
          data: sortedJurusan.map(j => j[1]),
          backgroundColor: '#FF8C00',
          borderColor: '#FF6B00',
          borderWidth: 2
        }]
      },
      options: {
        responsive: true,
        indexAxis: 'y',
        plugins: { legend: { display: false } }
      }
    });
  }
}

function showToast(message, type = 'info') {
  try {
    const container = document.getElementById('toast-container');
    if (!container) {
      console.error('Toast container tidak ditemukan');
      return;
    }
    
    const toast = document.createElement('div');
    const bgColor = type === 'success' ? 'bg-green-500' : type === 'error' ? 'bg-red-500' : 'bg-blue-500';
    
    toast.className = `toast ${bgColor} text-white px-6 py-4 rounded-lg shadow-lg`;
    toast.textContent = message;
    
    container.appendChild(toast);
    
    setTimeout(() => {
      try {
        if (toast.parentElement) {
          toast.style.animation = 'fadeOut 0.3s ease';
          setTimeout(() => {
            if (toast.parentElement) {
              toast.remove();
            }
          }, 300);
        }
      } catch (error) {
        console.error('Error removing toast:', error);
      }
    }, 3000);
  } catch (error) {
    console.error('Error menampilkan toast:', error);
  }
}


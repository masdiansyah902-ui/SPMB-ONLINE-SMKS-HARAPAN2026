function nextStep() {
  if (validateStep(currentStep)) {
    if (currentStep < totalSteps) {
      saveStepData();
      currentStep++;
      updateStepUI();
    }
  }
}

function prevStep() {
  if (currentStep > 1) {
    saveStepData();
    currentStep--;
    updateStepUI();
  }
}

function validateStep(step) {
  const form = document.getElementById('registration-form');
  const inputs = form.querySelectorAll(`#step-${step} [required]`);
  let isValid = true;
  
  inputs.forEach(input => {
    const errorMsg = input.nextElementSibling;
    let fieldValid = true;
    let errorText = '';
    
    if (!input.value.trim()) {
      fieldValid = false;
      errorText = 'Kolom ini harus diisi';
    } else {
      const fieldName = input.getAttribute('name');
      const value = input.value.trim();
      
      if (fieldName === 'nama_lengkap' || fieldName === 'tempat_lahir' || fieldName === 'nama_ayah' || fieldName === 'nama_ibu') {
        if (!/^[a-zA-Z\s]+$/.test(value)) {
          fieldValid = false;
          errorText = 'Hanya boleh huruf dan spasi';
        }
      }
      
      if (fieldName === 'nik') {
        if (!/^\d{16}$/.test(value)) {
          fieldValid = false;
          errorText = 'NIK harus 16 digit angka';
        }
      }
      
      if (fieldName === 'nisn') {
        if (!/^\d{10}$/.test(value)) {
          fieldValid = false;
          errorText = 'NISN harus 10 digit angka';
        }
      }
      
      if (fieldName === 'tanggal_lahir') {
        const selectedDate = new Date(value);
        const today = new Date();
        today.setHours(0, 0, 0, 0);
        
        if (selectedDate > today) {
          fieldValid = false;
          errorText = 'Tanggal lahir tidak boleh melebihi hari ini';
        } else if (selectedDate.getFullYear() < 1950) {
          fieldValid = false;
          errorText = 'Tanggal lahir tidak valid';
        }
      }
      
      if (fieldName === 'no_hp' || fieldName === 'no_hp_ayah' || fieldName === 'no_hp_ibu') {
        if (!/^(08|\+62)\d{9,11}$/.test(value)) {
          fieldValid = false;
          errorText = 'No HP harus dimulai 08 atau +62 (minimal 11 digit)';
        }
      }
      
      if (fieldName === 'email') {
        if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value)) {
          fieldValid = false;
          errorText = 'Format email tidak valid';
        }
      }
      
      if (fieldName === 'alamat') {
        if (value.length < 5) {
          fieldValid = false;
          errorText = 'Alamat minimal 5 karakter';
        }
      }
      
      if (fieldName === 'rt') {
        if (!/^\d{1,2}$/.test(value)) {
          fieldValid = false;
          errorText = 'RT hanya angka (1-2 digit)';
        } else if (parseInt(value) < 1 || parseInt(value) > 99) {
          fieldValid = false;
          errorText = 'RT harus antara 01-99';
        }
      }
      
      if (fieldName === 'kode_pos') {
        if (!/^\d{5}$/.test(value)) {
          fieldValid = false;
          errorText = 'Kode pos harus 5 digit angka';
        }
      }
      
      if (fieldName === 'tahun_lulus') {
        const year = parseInt(value);
        if (isNaN(year) || year < 2020 || year > 2026) {
          fieldValid = false;
          errorText = 'Tahun lulus harus 2020-2026';
        }
      }
      
      if (fieldName === 'nilai_rata_rata') {
        const nilai = parseFloat(value);
        if (isNaN(nilai) || nilai < 0 || nilai > 100) {
          fieldValid = false;
          errorText = 'Nilai harus antara 0-100';
        }
      }
      
      if (fieldName === 'pekerjaan_ayah' || fieldName === 'pekerjaan_ibu') {
        if (value.length < 3) {
          fieldValid = false;
          errorText = 'Pekerjaan minimal 3 karakter';
        }
      }
      
      if (fieldName === 'asal_sekolah') {
        if (value.length < 3) {
          fieldValid = false;
          errorText = 'Nama sekolah minimal 3 karakter';
        }
      }
    }
    
    if (!fieldValid) {
      input.classList.add('error');
      if (errorMsg && errorMsg.classList.contains('error-message')) {
        errorMsg.textContent = errorText;
        errorMsg.classList.add('show');
      }
      isValid = false;
    } else {
      input.classList.remove('error');
      if (errorMsg && errorMsg.classList.contains('error-message')) {
        errorMsg.classList.remove('show');
      }
    }
  });
  
  return isValid;
}

function saveStepData() {
  const form = document.getElementById('registration-form');
  const formData = new FormData(form);
  for (let [key, value] of formData.entries()) {
    registrationData[key] = value;
  }
}

function updateStepUI() {
  document.querySelectorAll('.form-step').forEach(step => step.classList.add('hidden'));
  document.getElementById(`step-${currentStep}`).classList.remove('hidden');
  
  const progress = (currentStep / totalSteps) * 100;
  document.getElementById('progress-bar').style.width = progress + '%';
  document.getElementById('progress-percentage').textContent = Math.round(progress) + '%';
  document.getElementById('current-step').textContent = currentStep;
  
  document.querySelectorAll('.step-indicator').forEach((indicator, index) => {
    const stepNum = index + 1;
    const circle = indicator.querySelector('div:first-child');
    
    if (stepNum < currentStep) {
      circle.className = 'w-10 h-10 rounded-full bg-green-500 text-white flex items-center justify-center font-bold mx-auto mb-2';
      circle.textContent = '✓';
    } else if (stepNum === currentStep) {
      circle.className = 'w-10 h-10 rounded-full bg-gradient-to-br from-orange-400 to-orange-600 text-white flex items-center justify-center font-bold mx-auto mb-2';
      circle.textContent = stepNum;
    } else {
      circle.className = 'w-10 h-10 rounded-full bg-gray-300 text-gray-600 flex items-center justify-center font-bold mx-auto mb-2';
      circle.textContent = stepNum;
    }
  });
  
  const btnPrev = document.getElementById('btn-prev');
  const btnNext = document.getElementById('btn-next');
  const btnSubmit = document.getElementById('btn-submit');
  
  if (currentStep === 1) {
    btnPrev.classList.add('hidden');
  } else {
    btnPrev.classList.remove('hidden');
  }
  
  if (currentStep === totalSteps) {
    btnNext.classList.add('hidden');
    btnSubmit.classList.remove('hidden');
  } else {
    btnNext.classList.remove('hidden');
    btnSubmit.classList.add('hidden');
  }
}

function resetForm() {
  currentStep = 1;
  registrationData = {};
  document.getElementById('registration-form').reset();
  updateStepUI();
}

async function handleRegistration(event) {
  event.preventDefault();
  
  if (validateStep(currentStep)) {
    saveStepData();
    registrationData.tanggal_daftar = new Date().toISOString();
    registrationData.gelombang = getCurrentWave();
    registrationData.status = 'Menunggu';
    registrationData.berkas_status = 'Belum';
    
    const submitBtn = document.getElementById('btn-submit');
    const originalText = submitBtn.textContent;
    submitBtn.disabled = true;
    submitBtn.innerHTML = '<div class="loading-spinner" style="width: 20px; height: 20px; margin: 0 auto;"></div>';
    
    try {
      const googleAppsScriptURL = 'https://script.google.com/macros/s/AKfycbw_qMlaIrUMqxei4pnnwcT3U62-QQiTLaMT6SEj_d6JNjceycZoMCu6TpbHQnZviWMI/exec';
      
      console.log('🔗 URL yang digunakan:', googleAppsScriptURL);
      console.log('📤 Mengirim data:', registrationData);
      
      if (!googleAppsScriptURL || !googleAppsScriptURL.startsWith('https://')) {
        throw new Error('URL server tidak valid');
      }
      
      const controller = new AbortController();
      const timeoutId = setTimeout(() => controller.abort(), REQUEST_TIMEOUT);
      
      try {
        // Konversi data ke format yang kompatibel dengan Google Sheets
        const formData = new FormData();
        for (const [key, value] of Object.entries(registrationData)) {
          formData.append(key, value || '');
        }
        
        // Coba fetch dengan mode 'no-cors'
        const response = await fetch(googleAppsScriptURL, {
          method: 'POST',
          body: formData,
          mode: 'no-cors',
          signal: controller.signal
        });
        
        clearTimeout(timeoutId);
        
        console.log('✅ Data terkirim ke server');
        console.log('📦 Data yang dikirim:', registrationData);
        
        lastSuccessfulRequest = Date.now();
        
        // Simpan data lokal sebagai backup
        try {
          const backupData = JSON.parse(localStorage.getItem('registrationBackup') || '[]');
          backupData.push({...registrationData, backup_timestamp: new Date().toISOString(), sent: true});
          if (backupData.length > 100) backupData.shift();
          localStorage.setItem('registrationBackup', JSON.stringify(backupData));
        } catch (storageError) {
          console.warn('⚠️ Storage backup failed:', storageError);
        }
        
        showSuccessModal(registrationData.nama_lengkap || 'Calon Peserta Didik', registrationData.gelombang);
        submitBtn.disabled = false;
        submitBtn.textContent = originalText;
        
      } catch (fetchError) {
        clearTimeout(timeoutId);
        
        if (fetchError.name === 'AbortError') {
          console.error('⏱️ Request timeout');
          throw new Error('REQUEST_TIMEOUT');
        }
        console.error('🔴 Fetch error detail:', fetchError);
        throw fetchError;
      }
      
    } catch (error) {
      console.error('❌ Registration Error:', error);
      
      let errorMsg = '❌ Terjadi kesalahan saat mengirim data.';
      
      if (error.message === 'REQUEST_TIMEOUT') {
        errorMsg = '⏱️ Server sedang sibuk (timeout). Silakan coba lagi dalam beberapa saat.';
      } else if (error instanceof TypeError) {
        errorMsg = '🌐 Periksa koneksi internet Anda. Pastikan Google Sheet URL valid.';
      } else if (error.message.includes('URL')) {
        errorMsg = '⚙️ Konfigurasi server tidak valid.';
      } else if (error.message.includes('Server error')) {
        errorMsg = '⚠️ Server tidak merespons dengan baik. Cek konfigurasi Google Apps Script.';
      }
      
      // Tetap simpan data lokal meski gagal
      try {
        const backupData = JSON.parse(localStorage.getItem('registrationBackup') || '[]');
        backupData.push({...registrationData, backup_timestamp: new Date().toISOString(), sent: false, error: error.message});
        if (backupData.length > 100) backupData.shift();
        localStorage.setItem('registrationBackup', JSON.stringify(backupData));
      } catch (e) {
        console.warn('⚠️ Backup gagal:', e);
      }
      
      showToast(errorMsg + ' Data Anda telah disimpan lokal.', 'error');
      submitBtn.disabled = false;
      submitBtn.textContent = originalText;
    }
  }
}


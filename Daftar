  <script>
// ===== SISTEM MONITORING KONEKSI & STABILITAS =====
let isOnline = navigator.onLine;
let connectionCheckInterval = null;
let lastSuccessfulRequest = Date.now();
const REQUEST_TIMEOUT = 30000; // 30 detik
const MAX_OFFLINE_TIME = 300000; // 5 menit

function initializeConnectionMonitoring() {
  // Monitor status online/offline
  window.addEventListener('online', () => {
    if (!isOnline) {
      isOnline = true;
      lastSuccessfulRequest = Date.now();
      showToast('✅ Koneksi internet pulih!', 'success');
      retryPendingRequests();
    }
  });
  
  window.addEventListener('offline', () => {
    isOnline = false;
    showToast('⚠️ Koneksi internet terputus. Data Anda aman tersimpan lokal.', 'error');
  });
  
  // Periodic connection check setiap 30 detik dengan timeout detection
  connectionCheckInterval = setInterval(async () => {
    try {
      const controller = new AbortController();
      const timeoutId = setTimeout(() => controller.abort(), 10000);
      
      await fetch('https://www.google.com/images/branding/googlelogo/1x/googlelogo_color_272x92dp.png', {
        method: 'HEAD',
        mode: 'no-cors',
        signal: controller.signal
      });
      
      clearTimeout(timeoutId);
      
      if (!isOnline) {
        isOnline = true;
        lastSuccessfulRequest = Date.now();
        showToast('✅ Koneksi kembali normal!', 'success');
      }
    } catch (e) {
      if (isOnline || Date.now() - lastSuccessfulRequest > MAX_OFFLINE_TIME) {
        isOnline = false;
      }
    }
  }, 30000);
}

function retryPendingRequests() {
  try {
    const backup = JSON.parse(localStorage.getItem('registrationBackup') || '[]');
    if (backup.length > 0) {
      showToast('🔄 Mencoba mengirim data yang tertunda...', 'info');
    }
  } catch (error) {
    console.error('Error reading backup data:', error);
  }
}

// ===== VARIABEL GLOBAL =====
let currentPage = 'home';
let currentStep = 1;
const totalSteps = 4;
let registrationData = {};
let allData = [];
let currentWave = 'Gelombang 1';
let currentBgColor = '#ffffff';
let requestRetryCount = 0;
const MAX_RETRIES = 3;

// ===== GELOMBANG CONFIGURATION =====
const waveConfig = {
  'Gelombang 1': { months: [1, 2, 3, 4], label: 'Januari - April', color: 'blue' },
  'Gelombang 2': { months: [5, 6], label: 'Mei - Juni', color: 'orange' },
  'Gelombang 3': { months: [7, 8, 9, 10, 11, 12], label: 'Juli - Desember', color: 'green' }
};

function getCurrentWave() {
  const currentMonth = new Date().getMonth() + 1; // getMonth() returns 0-11
  for (const [wave, config] of Object.entries(waveConfig)) {
    if (config.months.includes(currentMonth)) {
      return wave;
    }
  }
  return 'Gelombang 1'; // Default
}

function updateCurrentWaveDisplay() {
  currentWave = getCurrentWave();
  document.getElementById('admin-current-wave').textContent = currentWave;
}

const jurusanList = [
  { id: 1, nama: 'Teknik Komputer dan Jaringan', kode: 'TKJ', durasi: '3 Tahun', kapasitas: '40 siswa', icon: '💻', deskripsi: 'Belajar jaringan, server, dan keamanan siber modern', keuntungan: 'Peluang kerja tinggi' },
  { id: 2, nama: 'Manajemen Perkantoran', kode: 'MP', durasi: '3 Tahun', kapasitas: '40 siswa', icon: '📊', deskripsi: 'Manajemen kantor dan administrasi bisnis profesional', keuntungan: 'Karir di berbagai industri' },
  { id: 3, nama: 'Akuntansi & Keuangan Lembaga', kode: 'AKL', durasi: '3 Tahun', kapasitas: '40 siswa', icon: '💰', deskripsi: 'Pengelolaan keuangan dan akuntansi profesional', keuntungan: 'Demand tinggi' },
  { id: 4, nama: 'Bisnis Retail', kode: 'BR', durasi: '3 Tahun', kapasitas: '40 siswa', icon: '🛍️', deskripsi: 'Toko, penjualan, dan customer service terbaik', keuntungan: 'Peluang ekspansi luas' },
  { id: 5, nama: 'Desain Komunikasi Visual', kode: 'DKV', durasi: '3 Tahun', kapasitas: '40 siswa', icon: '🎨', deskripsi: 'Desain grafis, multimedia, dan branding kreatif', keuntungan: 'Industri kreatif' }
];

function showPage(pageName) {
  document.querySelectorAll('.page').forEach(page => page.classList.add('hidden'));
  const page = document.getElementById('page-' + pageName);
  if (page) {
    page.classList.remove('hidden');
    currentPage = pageName;
  }
  if (pageName === 'jurusan') populateJurusanList();
  if (pageName === 'register') { populateJurusanSelects(); resetForm(); }
  if (pageName === 'dashboard') loadDashboardData();
  window.scrollTo(0, 0);
}

